{
    "name": "oxc-inspector",
    "type": "module",
    "packageManager": "pnpm@10.15.1",
    "description": "A visual tool for inspecting and understanding your oxlint and oxfmt config.",
    "license": "MIT",
    "homepage": "https://github.com/lonewolfyx/oxc-inspector",
    "bugs": {
        "url": "https://github.com/lonewolfyx/oxc-inspector/issues"
    },
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "typecheck": "nuxt typecheck",
        "lint": "eslint .",
        "lint:fix": "eslint --fix",
        "prepare": "simple-git-hooks",
        "migrate": "npx @oxlint/migrate ./eslint.config.mjs",
        "dev:configs": "tsx ./src/configs.ts"
    },
    "dependencies": {
        "@tailwindcss/vite": "^4.2.1",
        "@tanstack/vue-table": "^8.21.3",
        "@vueuse/core": "^14.2.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-vue-next": "^0.545.0",
        "reka-ui": "^2.9.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.1",
        "vue": "^3.5.29",
        "vue-router": "^4.6.4"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^7.7.0",
        "@iconify-json/mdi": "^1.2.3",
        "@iconify-json/pajamas": "^1.2.15",
        "@iconify-json/ph": "^1.2.2",
        "@iconify-json/svg-spinners": "^1.2.4",
        "@nuxt/content": "^3.12.0",
        "@nuxt/eslint": "^1.15.2",
        "@nuxt/eslint-plugin": "^1.15.2",
        "@nuxt/icon": "^2.2.1",
        "@oxlint/migrate": "^1.51.0",
        "@shikijs/engine-javascript": "^4.0.2",
        "@shikijs/langs-precompiled": "^4.0.2",
        "@shikijs/themes": "^4.0.2",
        "@shikijs/transformers": "^4.0.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/json-schema": "^7.0.15",
        "@types/node": "^25.3.5",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/utils": "^8.57.0",
        "@vueuse/nuxt": "^14.2.1",
        "ansis": "^4.2.0",
        "bundle-require": "^5.1.0",
        "chokidar": "^5.0.0",
        "defu": "^6.1.4",
        "eslint": "^9.39.4",
        "find-up": "^8.0.0",
        "get-port-please": "^3.2.0",
        "json-schema": "^0.4.0",
        "lint-staged": "^16.3.2",
        "local-pkg": "^1.1.2",
        "mlly": "^1.8.1",
        "nuxt": "^4.3.1",
        "ofetch": "^1.5.1",
        "oxfmt": "^0.37.0",
        "oxlint": "^1.51.0",
        "oxlint-rules-meta": "^0.0.3",
        "pathe": "^2.0.3",
        "picocolors": "^1.1.1",
        "pkg-types": "^2.3.0",
        "shadcn-nuxt": "^2.4.3",
        "shiki": "^4.0.2",
        "simple-git-hooks": "^2.13.1",
        "textmate-grammar-glob": "^0.0.1",
        "tinyexec": "^1.0.2",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.9.3",
        "ws": "^8.19.0"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged",
        "commit-msg": "node scripts/verify-commit.js"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
